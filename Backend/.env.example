# ──────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your local values.
# Never commit ".env" — only ".env.example" should be in version control.
# ──────────────────────────────────────────────────────────────────────────

# HTTP server
PORT=4000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD= Supremocaloy19@
DB_NAME=hlc_enrollment

# JWT
# Use a long random string (e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=12h

# CORS — comma-separated list of allowed frontend origins.
# Use "*" only during local development.
CORS_ORIGIN=*
